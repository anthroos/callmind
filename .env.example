# CallMind configuration
GEMINI_API_KEY=your-gemini-api-key-here

# Qdrant (default: localhost Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Collection (separate from OpenExp)
CALLMIND_COLLECTION=callmind_memories

# Unkey (API key management)
UNKEY_API_ID=your-unkey-api-id
UNKEY_ROOT_KEY=your-unkey-root-key

# Server
CALLMIND_HOST=0.0.0.0
CALLMIND_PORT=8000

# Upload directory
CALLMIND_UPLOAD_DIR=./uploads
